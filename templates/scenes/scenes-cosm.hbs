<div class="tab{{#if tab.active}} active{{/if}}" data-group="{{tab.group}}" data-tab="{{tab.id}}">
  <div class="form-group cosm-primary">
    <select name="flags.torgeternity.cosm" class="cosm" data-dtype="String" data-field="cosm">
      {{selectOptions cosmTypes selected=document.torg.cosm localize=true sort=true}}
    </select>

    <select name="flags.torgeternity.zone" class="zone-type" data-dtype="String" data-field="zone">
      {{selectOptions zones selected=document.torg.zone localize=true sort=true}}
    </select>
  </div>

  <div class="form-group cosm-secondary" {{#unless document.torg.displayCosm2}}style="display:none" {{/unless}}>
    <label>{{localize "torgeternity.sheetLabels.secondaryCosm"}}</label>
    <select name="flags.torgeternity.cosm2" class="cosm-secondary" data-dtype="String" data-field="cosm2">
      {{selectOptions cosmTypes selected=document.torg.cosm2 localize=true sort=true}}
    </select>
  </div>

  <div class="form-group cosm-other-name1"
    {{#if (ne document.torg.cosm 'other' )}}style="display:none" {{/if}}>
    <label>{{localize "torgeternity.sheetLabels.scenes.cosmOtherName1"}}</label>
    <input type="text" name="flags.torgeternity.otherName1" class="cosm-other-name" data-dtype="String"
      value="{{document.torg.otherName1}}">
  </div>

  <div class="form-group cosm-other-name2"
    {{#if (ne document.torg.cosm2 'other' )}}style="display:none" {{/if}}>
    <label>{{localize "torgeternity.sheetLabels.scenes.cosmOtherName2"}}</label>
    <input type="text" name="flags.torgeternity.otherName2" class="cosm-other-name" data-dtype="String"
      value="{{document.torg.otherName2}}">
  </div>

  <fieldset class="form-group cosm-axioms">
    <legend>{{localize 'torgeternity.stats.axioms'}}</legend>
    <div>
      <table>
        <thead>
          <td class="axiom-label">{{localize 'torgeternity.sheetLabels.magic'}}</td>
          <td class="axiom-label">{{localize 'torgeternity.sheetLabels.social'}}</td>
          <td class="axiom-label">{{localize 'torgeternity.sheetLabels.spirit'}}</td>
          <td class="axiom-label">{{localize 'torgeternity.sheetLabels.tech'}}</td>
        </thead>
        <tbody>
          <td class="axiom-value">
            <input type="text" name="flags.torgeternity.axioms.magic"
              value="{{document.flags.torgeternity.axioms.magic}}">
          </td>
          <td class="axiom-value">
            <input type="text" name="flags.torgeternity.axioms.social"
              value="{{document.flags.torgeternity.axioms.social}}">
          </td>
          <td class="axiom-value">
            <input type="text" name="flags.torgeternity.axioms.spirit"
              value="{{document.flags.torgeternity.axioms.spirit}}">
          </td>
          <td class="axiom-value">
            <input type="text" name="flags.torgeternity.axioms.tech"
              value="{{document.flags.torgeternity.axioms.tech}}">
          </td>
        </tbody>
      </table>
    </div>
  </fieldset>
</div>